# Copy this file to `.env` and fill in your own key(s). `.env` is read by
# gauge_core (providers/agent) and exported by run_gauge.sh, and must never be
# committed to version control.

# --- DeepSeek (default chat + reasoning provider) ---------------------------
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- OpenAI (optional alternate provider) -----------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# --- GAUGE Assistant defaults (optional) ------------------------------------
# Which provider the chat uses by default, and which (reasoning) model writes
# the Deep Report. Must be names from gauge_core.providers.PROVIDERS.
GAUGE_ASSISTANT_PROVIDER=deepseek-chat
GAUGE_REPORT_PROVIDER=deepseek-reasoner

# Allow the Assistant to query external biomedical databases (OpenTargets,
# PubChem, UniProt, Europe PMC). The sidebar toggle controls this per session;
# this is only a default hint. Requires internet access.
GAUGE_ENABLE_EXTERNAL=false
